   408|   408|
   409|   409|    <script>
   410|   410|        const observerOptions = {
   411|   411|            root: null,
   412|   412|            rootMargin: '0px',
   413|   413|            threshold: 0.15
   414|   414|        };
   415|   415|
   416|   416|        const observer = new IntersectionObserver((entries) => {
   417|   417|            entries.forEach((entry) => {
   418|   418|                if (entry.isIntersecting) {
   419|   419|                    entry.target.classList.add('active');
   420|   420|                } else {
   421|   421|                    entry.target.classList.remove('active');
   422|   422|                }
   423|   423|            });
   424|   424|        }, observerOptions);
   425|   425|
   426|   426|        document.querySelectorAll('.reveal').forEach((element) => {
   427|   427|            observer.observe(element);
   428|   428|        });
   429|   429|    </script>
   430|   430|</body>
