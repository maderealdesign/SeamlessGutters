                <div class="absolute inset-0 hero-overlay"></div>
            </div>

            <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
                <div class="max-w-3xl">
                    <div class="reveal inline-flex items-center space-x-2 bg-brand-green/20 backdrop-blur-md border border-brand-green/30 px-3 py-1.5 sm:px-4 sm:py-2 rounded-full mb-5 sm:mb-6">
                        <span class="flex h-2 w-2 rounded-full bg-green-400 animate-pulse"></span>
                        <span class="text-green-300 font-semibold text-xs sm:text-sm uppercase tracking-wider">Knowledge Base</span>
                    </div>
                    <h1 class="reveal reveal-delay-100 font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-4 sm:mb-6">
                        Frequently Asked <br>
                        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#2EC8A0] to-[#15803d]">Questions.</span>
                    </h1>
                    <p class="reveal reveal-delay-200 text-base sm:text-lg lg:text-xl text-gray-300 mb-8 sm:mb-8 max-w-2xl leading-relaxed">
