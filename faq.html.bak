    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Open Sans', 'sans-serif'],
                        heading: ['Montserrat', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            green: '#2EC8A0', /* Extracted from Donor */
                            dark: '#2d3748',
                            slate: '#1e293b',
                            light: '#f8fafc',
                        }
                    }
                }
            }
        }
    </script>
    <style>

    <script src="auto-menu-generator.js" defer></script>
    <script src="menu-loader.js" defer></script>
        /* Custom Styles for Polish */
        .gradient-text { background: linear-gradient(135deg, #2EC8A0 0%, #15803d 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .bg-gradient-brand { background: linear-gradient(135deg, #2EC8A0 0%, #15803d 100%); }
        .hero-overlay { background: linear-gradient(to right, rgba(30, 41, 59, 0.95), rgba(30, 41, 59, 0.7)); }
        
        /* Scroll Reveal Animations */
        .reveal { opacity: 0; transform: translateY(20px); transition: all 0.6s cubic-bezier(0.5, 0, 0, 1); }
        .reveal.active { opacity: 1; transform: translateY(0); }
        .reveal-delay-100 { transition-delay: 100ms; }
        .reveal-delay-200 { transition-delay: 200ms; }
        .reveal-delay-300 { transition-delay: 300ms; }
    </style>

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What exactly is seamless aluminium guttering?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Seamless aluminium guttering is a continuous length of gutter manufactured on-site to the exact dimensions of your property. Because it has no joints along the main runs, it completely eliminates the weakest points where traditional plastic gutters typically leak."
          }
        },
        {
          "@type": "Question",
          "name": "How long will an aluminium guttering system last?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Aluminium is highly resistant to corrosion and rust. Under standard UK weather conditions, a properly installed seamless aluminium gutter system can easily last upwards of 30 years, significantly outperforming traditional uPVC alternatives."
          }
        },
        {
          "@type": "Question",
          "name": "Are seamless gutters more expensive than plastic?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "While the initial investment may be slightly higher than off-the-shelf plastic uPVC, the long-term value is vastly superior. Seamless aluminium requires virtually no maintenance, does not crack or fade, and eliminates the need for frequent, costly repairs caused by leaking joints."
          }
        },
        {
          "@type": "Question",
          "name": "Do you offer different colours and finishes?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Our seamless aluminium coil comes with a factory-applied, highly durable powder coating. We offer a range of standard colours, including Black, White, Anthracite Grey, and Brown, designed to complement both modern and traditional Lancashire stone properties."
          }
        },
        {
          "@type": "Question",
          "name": "How long does the installation process take?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Most standard domestic installations (e.g., a 3-bedroom semi-detached house) can be fully completed within a single day. Our mobile extrusion machine allows us to work incredibly efficiently on-site."
          }
        },
        {
          "@type": "Question",
          "name": "What areas do you cover?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We are based at Pine Garth Farm in Colne, Lancashire. Our standard service area covers Colne, Skipton, Burnley, Barrowford, Earby, Keighley, and the surrounding towns and villages across the Lancashire and Yorkshire borders."
          }
        }
      ]
    }
    </script>
</head>
<body class="font-sans text-brand-slate bg-brand-light antialiased selection:bg-brand-green selection:text-white">

