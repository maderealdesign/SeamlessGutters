                    </div>
                    <div class="reveal reveal-delay-200 p-4 border-t md:border-t-0 md:border-l border-gray-100">
                        <div class="mx-auto w-12 h-12 bg-brand-green/10 rounded-full flex items-center justify-center mb-4">
                            <svg class="w-6 h-6 text-brand-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path></svg>
